<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="30.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.GuestController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    <children>
        
        <!-- Left Side: Add/Edit Form -->
        <VBox prefWidth="350.0" minWidth="350.0" spacing="20.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16; -fx-padding: 24; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16;">
            <children>
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" text="Guest Profile Form" />
                
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="form-label" text="First Name" />
                        <TextField fx:id="txtFirstName" promptText="Enter first name" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="form-label" text="Last Name" />
                        <TextField fx:id="txtLastName" promptText="Enter last name" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="form-label" text="Email Address" />
                        <TextField fx:id="txtEmail" promptText="e.g. guest@domain.com" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="form-label" text="Phone Number" />
                        <TextField fx:id="txtPhone" promptText="e.g. 555-0100" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="form-label" text="ID Card / Passport No." />
                        <TextField fx:id="txtIdCard" promptText="e.g. ID-4492" styleClass="text-field" />
                    </children>
                </VBox>
                
                <Label fx:id="lblError" style="-fx-text-fill: #ef4444; -fx-font-weight: 500;" wrapText="true" />
                <Label fx:id="lblSuccess" style="-fx-text-fill: #22c55e; -fx-font-weight: 500;" wrapText="true" />

                <!-- Action Buttons -->
                <VBox spacing="10.0">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSaveGuest" prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-primary" text="Save Guest" />
                                <Button fx:id="btnClear" mnemonicParsing="false" onAction="#handleClearForm" prefHeight="40.0" styleClass="btn-secondary" text="Clear" />
                            </children>
                        </HBox>
                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDeleteGuest" prefHeight="40.0" prefWidth="302.0" styleClass="btn-danger" text="Delete Guest Profile" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- Right Side: Guest Directory -->
        <VBox HBox.hgrow="ALWAYS" spacing="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" text="Guest Directory" />
                        <TextField fx:id="txtSearch" onKeyReleased="#handleSearch" prefWidth="300.0" promptText="Search by name, phone or ID Card..." styleClass="text-field" style="-fx-padding: 8 12 8 12; -fx-background-color: #162032;" />
                    </children>
                </HBox>
                
                <TableView fx:id="tblGuests" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableClick">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colFirstName" prefWidth="120.0" text="First Name" />
                        <TableColumn fx:id="colLastName" prefWidth="120.0" text="Last Name" />
                        <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email" />
                        <TableColumn fx:id="colPhone" prefWidth="130.0" text="Phone" />
                        <TableColumn fx:id="colIdCard" prefWidth="110.0" text="ID Card" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        
    </children>
</HBox>
